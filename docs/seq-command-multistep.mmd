sequenceDiagram
    title Multi-Step Command (e.g. /broadcast)

    participant CM as ChannelManager<br/>(channel/manager.go)
    participant PR as PluginRegistry<br/>(plugin/manager.go)
    participant Auth as Authorizer<br/>(authz/authorizer.go)
    participant SMA as StateManagerAdapter<br/>(channel/state_adapter.go)
    participant SM as StateManager<br/>(state/manager.go)
    participant Store as DialogStorage<br/>(Redis)
    participant UR as UpdateRouter<br/>(plugin/router.go)
    participant Plugin as Plugin
    participant Sender as SenderAPI
    participant AR as AdapterRegistry<br/>(channel/registry.go)

    Note over CM: OnUpdate: TextInput{"/broadcast"}

    CM->>CM: handleCommand()

    CM->>PR: GetCommandDefinition("broadcast")
    PR-->>CM: CommandDefinition{Requirements}
    CM->>PR: GetPluginIDByCommand("broadcast")
    PR-->>CM: pluginID

    CM->>Auth: CheckCommand(ctx, userID, pluginID, "broadcast", requirements)
    Auth-->>CM: true, nil

    CM->>SMA: IsPreservesDialog("broadcast")
    SMA-->>CM: false
    CM->>SMA: CancelCommand(ctx, userID, channelType)
    SMA->>SM: CancelCommand(ctx, userID)
    SM->>Store: Delete(ctx, userID)

    CM->>SMA: StartCommand(ctx, userID, channelType, "broadcast", locale)
    SMA->>SM: IsCommandImmediate("broadcast")
    SM-->>SMA: false (has steps)
    SMA->>SM: StartCommand(ctx, userID, "broadcast", locale)
    SM->>SM: handler.CreateNewState("broadcast")
    SM->>SM: handler.BuildStepMessage(state, locale)
    Note over SM: First step: "target"<br/>Options: [to_user, to_project]
    SM->>Store: Save(ctx, userID, dialogState)
    SM-->>SMA: Message{promptMsg}
    SMA-->>CM: StateResult{IsComplete: false, Message: promptMsg}

    CM->>AR: SendToChat(ctx, channelType, chatID, promptMsg)
    Note over AR: → "Choose target:" [to_user] [to_project]

    rect rgb(240, 248, 255)
        Note over CM, Store: Step 1: user selects "to_user" (CallbackInput)

        Note over CM: OnUpdate: CallbackInput{Data: "to_user"}
        CM->>CM: handleInput()
        CM->>SMA: ProcessInput(ctx, userID, channelType, CallbackInput{"to_user"}, locale)
        SMA->>SM: ProcessInput(ctx, userID, CallbackInput{"to_user"}, locale)
        SM->>Store: Load(ctx, userID)
        Store-->>SM: DialogState{CommandName: "broadcast", Params: {}}
        SM->>SM: handler.RestoreState → ProcessInput → BuildStepMessage
        Note over SM: Validates "to_user", Branch → next step: "user_id"
        SM->>Store: Save(ctx, userID, updatedState)
        SM-->>SMA: Message, nil (no CommandRequest → incomplete)
        SMA-->>CM: StateResult{IsComplete: false, Message: "Enter user ID:"}

        CM->>AR: SendToChat(ctx, channelType, chatID, msg)
    end

    rect rgb(255, 248, 240)
        Note over CM, Store: Step 2: user enters user ID (TextInput)

        Note over CM: OnUpdate: TextInput{"12345"}
        CM->>CM: handleInput()
        CM->>SMA: ProcessInput(ctx, userID, channelType, TextInput{"12345"}, locale)
        SMA->>SM: ProcessInput(ctx, userID, TextInput{"12345"}, locale)
        SM->>Store: Load(ctx, userID)
        Store-->>SM: DialogState{Params: {target: "to_user"}}
        SM->>SM: handler.ProcessInput → next step: "message_text"
        SM->>Store: Save(ctx, userID, updatedState)
        SM-->>SMA: Message, nil
        SMA-->>CM: StateResult{IsComplete: false, Message: "Enter message:"}

        CM->>AR: SendToChat(...)
    end

    rect rgb(240, 255, 240)
        Note over CM, Store: Step 3: user enters message text → dialog complete

        Note over CM: OnUpdate: TextInput{"Hello everyone!"}
        CM->>CM: handleInput()
        CM->>SMA: ProcessInput(ctx, userID, channelType, TextInput{"Hello..."}, locale)
        SMA->>SM: ProcessInput(ctx, userID, TextInput{"Hello..."}, locale)
        SM->>Store: Load(ctx, userID)
        SM->>SM: handler.ProcessInput → all steps complete
        SM->>Store: Delete(ctx, userID)
        SM-->>SMA: Message, &CommandRequest{Params: {target, user_id, message_text}}
        SMA-->>CM: StateResult{IsComplete: true,<br/>Params: {target, user_id, message_text}}
    end

    Note over CM: handleInput: send message first, then route

    CM->>AR: SendToChat(ctx, channelType, chatID, resultMessage)

    CM->>UR: Route(ctx, CommandRequest{UserID, ChannelType,<br/>ChatID, "broadcast", Params, Locale})
    UR->>UR: plugins.GetByCommand("broadcast")
    UR->>Plugin: HandleEvent(ctx, messengerEvent)

    Plugin->>Sender: Reply(ctx, triggerData, Message)
    Sender->>AR: SendToChat(ctx, channelType, chatID, Message)

    Plugin-->>UR: EventResponse{Status: "ok"}
