sequenceDiagram
    title Plugin-to-Plugin Communication

    participant PluginA as WASM Plugin A<br/>("notifications")
    participant HostAPI as Host API<br/>(hostapi/host_plugins.go)
    participant Perms as Permissions<br/>(hostapi/permissions.go)
    participant PM as PluginRegistry<br/>(CallPlugin)
    participant PluginB as WASM Plugin B<br/>("analytics")
    participant Bus as EventBus<br/>(eventbus/eventbus.go)

    Note over PluginA: During HandleEvent execution,<br/>Plugin A needs to call Plugin B

    rect rgb(230, 245, 255)
        Note over PluginA, PluginB: Path 1: Direct call via call_plugin

        PluginA->>HostAPI: call_plugin({Target: "analytics", Method: "track", Params: {...}})
        HostAPI->>Perms: CheckPermission("notifications", "plugins:call:analytics")
        Perms-->>HostAPI: ok

        rect rgb(220, 240, 255)
            Note over HostAPI: Call chain & depth tracking
            HostAPI->>HostAPI: chain = callChainFromContext(ctx)
            Note right of HostAPI: chain = ["notifications"]
            HostAPI->>HostAPI: checkCallCycle(chain, "analytics")
            Note right of HostAPI: No cycle detected
            HostAPI->>HostAPI: depth = callDepthFromContext(ctx)
            alt depth >= MaxCallDepth (5)
                HostAPI-->>PluginA: error: "call depth exceeded"
            end
            HostAPI->>HostAPI: ctx = withCallDepth(ctx, "analytics")
            Note right of HostAPI: chain = ["notifications", "analytics"]<br/>depth = 1
        end

        HostAPI->>HostAPI: callCtx = WithTimeout(ctx, wasmCallPluginMaxTimeout)
        HostAPI->>PM: CallPlugin(callCtx, "analytics", "track", params)
        PM->>PluginB: HandleEvent(callCtx, Event{TriggerType: TriggerEvent, Data: callData})
        PluginB-->>PM: EventResponse{Data: result}
        PM-->>HostAPI: result
        HostAPI-->>PluginA: result (written to WASM memory)
    end

    rect rgb(255, 245, 230)
        Note over PluginA, Bus: Path 2: Async event via publish_event

        PluginA->>HostAPI: publish_event({Topic: "user.action", Payload: {...}})
        HostAPI->>Perms: CheckPermission("notifications", "plugins:events")
        Perms-->>HostAPI: ok

        HostAPI->>HostAPI: pubCtx = WithTimeout(ctx, wasmPublishEventMaxTimeout)
        HostAPI->>HostAPI: pubCtx = ContextWithPluginID(pubCtx, "notifications")

        HostAPI->>Bus: Publish(pubCtx, "user.action", payload)

        rect rgb(255, 240, 225)
            Note over Bus: At-least-once delivery with retries
            Bus->>Bus: Find all subscribed handlers

            loop For each handler
                Bus->>Bus: deliverWithRetry(ctx, handler, topic, payload)
                Note right of Bus: MaxRetries: 3<br/>Backoff: [100ms, 500ms, 2s]
                alt Delivery succeeds
                    Bus->>PluginB: handler(ctx, "user.action", payload)
                    PluginB-->>Bus: nil
                    Bus->>Bus: incMetric("user.action", "delivered")
                else All retries exhausted
                    Bus->>Bus: addToDLQ(topic, payload, pluginID, err)
                    Note right of Bus: DLQ entry stored<br/>(max 1000 entries, FIFO eviction)
                    Bus->>Bus: incMetric("user.action", "dead_lettered")
                end
            end
        end

        Bus-->>HostAPI: error | nil
        HostAPI-->>PluginA: ok
    end
