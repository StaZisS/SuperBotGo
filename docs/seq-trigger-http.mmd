sequenceDiagram
    title HTTP Trigger

    participant HTTP as HTTPTriggerHandler<br/>(trigger/http.go)
    participant Reg as TriggerRegistry<br/>(trigger/registry.go)
    participant TR as TriggerRouter<br/>(trigger/router.go)
    participant PM as PluginManager<br/>(plugin/manager.go)
    participant Plugin as WasmPlugin<br/>(wasm/adapter/adapter.go)
    participant WASM as WASM Module
    participant Metrics as Metrics<br/>(metrics/metrics.go)

    Note over HTTP: POST /api/triggers/http/{pluginID}/{path}

    HTTP->>HTTP: Parse URL → pluginID, path
    HTTP->>HTTP: statusRecorder wraps ResponseWriter

    HTTP->>Reg: LookupHTTP(pluginID, path, method)
    Reg-->>HTTP: triggerName

    rect rgb(255, 248, 240)
        Note over HTTP, Reg: API Key Authentication
        HTTP->>Reg: GetAPIKey(pluginID)
        Reg-->>HTTP: apiKey
        alt apiKey is set
            HTTP->>HTTP: Check X-Trigger-Key header
            Note over HTTP: 401 Unauthorized if mismatch
        end
    end

    HTTP->>HTTP: io.ReadAll(LimitReader(body, 10MB))
    HTTP->>HTTP: Build HTTPTriggerData{Method, Path,<br/>Query, Headers, Body, RemoteAddr}
    HTTP->>HTTP: Create Event{ID: generateID(),<br/>TriggerType: TriggerHTTP,<br/>TriggerName, PluginID, Timestamp, Data}

    HTTP->>TR: RouteEvent(ctx, event)
    TR->>PM: All()
    TR->>TR: allPlugins[event.PluginID]
    TR->>Plugin: HandleEvent(ctx, event)

    Plugin->>Plugin: json.Marshal(event) → eventJSON
    Plugin->>WASM: CallHandleEvent(ctx, eventJSON, config)
    Note over WASM: Plugin processes request

    WASM-->>Plugin: resultJSON
    Plugin->>Plugin: json.Unmarshal → EventResponse
    Plugin-->>TR: EventResponse
    TR-->>HTTP: EventResponse

    rect rgb(240, 255, 240)
        Note over HTTP: Response construction

        HTTP->>HTTP: json.Unmarshal(resp.Data) → HTTPResponseData
        HTTP->>HTTP: Set response headers from HTTPResponseData.Headers
        Note right of HTTP: Default Content-Type: application/json<br/>Default StatusCode: 200
        HTTP->>HTTP: WriteHeader(statusCode)
        HTTP->>HTTP: Write(httpResponseData.Body)
    end

    HTTP->>Metrics: HTTPTriggerDuration.Observe(duration)
    HTTP->>Metrics: HTTPTriggerTotal.Inc(pluginID, method, statusCode)
